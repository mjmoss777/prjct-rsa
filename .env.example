# Database
DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenRouter AI
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-4o"
NVIDIA_API_KEY=

# Storage (local | s3)
STORAGE_BACKEND="local"

# S3-compatible storage (R2, Backblaze B2, MinIO) — only needed when STORAGE_BACKEND=s3
S3_ENDPOINT=
S3_REGION="auto"
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Cloudflare Turnstile (optional — auth works without it)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Polar.sh (Payments)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID=

# Uploadcare (blog image uploads)
NEXT_PUBLIC_UC_PUB_KEY=
UC_SECRET_KEY=

# RESEND
RESEND_API_KEY=
RESEND_EMAIL=onboarding@resend.dev
